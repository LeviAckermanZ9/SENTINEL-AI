# SENTINEL-AI Environment Configuration
# Copy to .env and fill in your values. Never commit .env to version control.

# --- HuggingFace ---
HF_TOKEN=hf_xxxx                          # Only needed for USE_API_LLM=true
USE_API_LLM=false                          # false=Flan-T5-XL local, true=Mistral API

# --- ChromaDB ---
CHROMA_HOST=chromadb                       # Docker service name (localhost if running locally)
CHROMA_PORT=8000
CHROMA_TOKEN=sentinel-chroma-token

# --- JWT Authentication ---
JWT_SECRET_KEY=<generate with secrets.token_hex(32)>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# --- AWS (for Terraform) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# --- Monitoring ---
GRAFANA_ADMIN_PASSWORD=sentinel_admin

# --- Alerting (optional) ---
SLACK_WEBHOOK_URL=

# --- Model Configuration ---
MODEL_DIR=./models
BERT_MODEL=bert-base-uncased
BART_MODEL=facebook/bart-large-cnn
NER_MODEL=dslim/bert-base-NER
EMBEDDING_MODEL=all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
